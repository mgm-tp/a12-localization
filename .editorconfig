root = true

[**]
indent_style = tab
trim_trailing_whitespace = true
insert_final_newline = false

[*.{adoc,md}]
trim_trailing_whitespace = false

[*.{yaml,json}]
indent_style = space
indent_size = 2

# npm adds final newline on changing the file
[{package,package-lock}.json]
insert_final_newline = true

[*.{xml,xsd,gradle,groovy}]
indent_style = space
indent_size = 4
