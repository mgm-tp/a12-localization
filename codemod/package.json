{
  "name": "@com.mgmtp.a12.utils/utils-localization-codemod",
  "version": "8.0.1",
  "description": "Localization Codemod",
  "author": "mgm technology partners",
  "license": "(EUPL-1.2 OR LicenseRef-commercial)",
  "bin": "lib/cli.js",
  "type": "module",
  "scripts": {
    "clean": "git clean -fx .",
    "build": "node --run compile",
    "compile": "tsc",
    "watch": "tsc --watch",
    "runner": "node --import ./scripts/resolveSnapshot.ts --test --test-reporter=dot",
    "test": "node --run runner -- \"lib/test/*.test.js\"",
    "test:updateSnapshots": "node --run runner -- --test-update-snapshots \"lib/test/*.test.js\""
  },
  "devDependencies": {
    "@com.mgmtp.a12.devtools/tsconfig": "catalog:a12ranges",
    "@types/node": "catalog:ranges",
    "typescript": "catalog:ranges"
  },
  "dependencies": {
    "@com.mgmtp.a12.devtools/codemod": "catalog:a12ranges",
    "ts-morph": "catalog:ranges"
  },
  "files": [
    "lib",
    "!lib/test",
    "!lib/testData",
    "src",
    "!src/test",
    "!src/testData",
    "cyclonedx.json",
    "NOTICE",
    "THIRD_PARTY_NOTICES",
    "licenses"
  ],
  "exports": null
}
