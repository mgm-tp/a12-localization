{
	"editor.parameterHints.enabled": true,
	"editor.rulers": [80, 120],
	"path-intellisense.extensionOnImport": false,
	"js/ts.validate.enabled": true,
	"js/ts.preferences.importModuleSpecifierEnding": "js",
	"js/ts.tsdk.path": "./node_modules/typescript/lib",
	"[typescript][typescriptreact][jsonc]": {
		"editor.formatOnSave": true,
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"editor.codeActionsOnSave": ["source.organizeImports", "source.fixAll.eslint"],
	"eslint.options": {
		"flags": ["unstable_native_nodejs_ts_config"]
	}
}
