{
    "testCases": [
        {
            "id": "time_0",
            "active": true,
            "description": "template + default time type",
            "parameters": {
                "value": "14:14:14",
                "conversionConfigId": "Time_defaultValues"
            },
            "expectation": {
                "convertedValue": "1970-01-01T14:14:14.000Z",
                "type": "Date"
            }
        },
        {
            "id": "time_1",
            "active": true,
            "description": "template + default time type without config",
            "parameters": {
                "value": "14:14:14",
                "conversionConfigId": "Time_default"
            },
            "expectation": {
                "convertedValue": "1970-01-01T14:14:14.000Z",
                "type": "Date"
            }
        },
        {
            "id": "time_2",
            "active": true,
            "description": "time type format ss.mm.HH",
            "parameters": {
                "value": "36.22.10",
                "conversionConfigId": "Time_ss.mm.HH"
            },
            "expectation": {
                "convertedValue": "1970-01-01T10:22:36.000Z",
                "type": "Date"
            }
        },
        {
            "id": "time_3",
            "active": true,
            "description": "time type format ss'x'mm'x'hha",
            "parameters": {
                "value": "36x22x10PM",
                "conversionConfigId": "Time_ss'x'mm'x'hha"
            },
            "expectation": {
                "convertedValue": "1970-01-01T22:22:36.000Z",
                "type": "Date"
            }
        },
        {
            "id": "time_4",
            "active": true,
            "description": "time type format HH:mm",
            "parameters": {
                "value": "10:22",
                "conversionConfigId": "Time_HH:mm"
            },
            "expectation": {
                "convertedValue": "1970-01-01T10:22:00.000Z",
                "type": "Date"
            }
        },
        {
            "id": "time_5",
            "active": true,
            "description": "time type format HH",
            "parameters": {
                "value": "10",
                "conversionConfigId": "Time_HH"
            },
            "expectation": {
                "convertedValue": "1970-01-01T10:00:00.000Z",
                "type": "Date"
            }
        },
        {
            "id": "time_6",
            "active": true,
            "description": "time type format hh a",
            "parameters": {
                "value": "10 PM",
                "conversionConfigId": "Time_hh_a"
            },
            "expectation": {
                "convertedValue": "1970-01-01T22:00:00.000Z",
                "type": "Date"
            }
        },
        {
            "id": "time_7",
            "active": true,
            "description": "time type format mm",
            "parameters": {
                "value": "22",
                "conversionConfigId": "Time_mm"
            },
            "expectation": {
                "convertedValue": "1970-01-01T00:22:00.000Z",
                "type": "Date"
            }
        },
        {
            "id": "time_null",
            "active": true,
            "description": "time type null",
            "parameters": {
                "value": null,
                "conversionConfigId": "Time_default"
            },
            "expectation": {
                "convertedValue": null
            }
        },
        {
            "id": "time_empty",
            "active": true,
            "description": "time type empty",
            "parameters": {
                "value": "",
                "conversionConfigId": "Time_default"
            },
            "expectation": {
                "convertedValue": null
            }
        }

    ]
}