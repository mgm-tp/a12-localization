{
    "testCases": [
        {
            "id": "datefragment_0",
            "active": true,
            "description": "template + default date fragment MM-dd",
            "parameters": {
                "value": "2000-02-14T00:00:00.000Z",
                "type": "Date",
                "conversionConfigId": "DateFragment_defaultValues"
            },
            "expectation": {
                "convertedValue": "02-14"
            }
        },
        {
            "id": "datefragment_1",
            "active": true,
            "description": "template + default date fragment MM-dd without config",
            "parameters": {
                "value": "2000-02-14T00:00:00.000Z",
