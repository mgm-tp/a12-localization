{
    "testCases": [
        {
            "id": "daterange_0",
            "active": true,
            "description": "template + default date range type",
            "parameters": {
                "value": ["2024-02-01T00:00:00.000Z","2024-02-14T00:00:00.000Z"],
                "type": "DateArray",
                "conversionConfigId": "DateRange_defaultValues"
            },
            "expectation": {
                "convertedValue": "2024-02-01/2024-02-14"
            }
        },
        {
